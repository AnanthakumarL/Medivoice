# Vite Environment Variables
# Backend API URL
VITE_API_URL=http://localhost:5000/api

# Chatbot API URL (can point to local Flask server or backend proxy)
# Example to use backend proxy: VITE_CHATBOT_URL=http://localhost:5000/api/chatbot
VITE_CHATBOT_URL=http://localhost:5001

# Application Environment
VITE_APP_ENV=development

# Demo Mode (set to 'true' to enable demo mode, 'false' for real API)
VITE_DEMO_MODE=false