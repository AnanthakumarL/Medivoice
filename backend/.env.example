# Environment Configuration
NODE_ENV=development
PORT=5000

# MongoDB (Local/Compass) Configuration
# Use this when running MongoDB locally or connecting via MongoDB Compass
MONGODB_URI=mongodb://127.0.0.1:27017/medihub
MONGODB_URI_TEST=mongodb://127.0.0.1:27017/medihub_test

# JWT Configuration
JWT_SECRET=your-super-secure-jwt-secret-key-at-least-32-characters-long
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-token-secret-key
JWT_REFRESH_EXPIRES_IN=30d

# Email Configuration (for password reset, verification, etc.)
EMAIL_FROM=noreply@medihub.com
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# Cloudinary Configuration (for file uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Redis Configuration (for caching and session management)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Frontend URLs (for CORS)
FRONTEND_URL=https://your-frontend-domain.com
ADMIN_URL=https://your-admin-panel.com
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX_REQUESTS=5

# Security
BCRYPT_SALT_ROUNDS=12
SESSION_SECRET=your-session-secret-key
PASSWORD_MIN_LENGTH=8

# API Configuration
API_VERSION=v1
API_PREFIX=/api

# API Keys for external integrations
VALID_API_KEYS=api-key-1,api-key-2,api-key-3

# File Upload Configuration
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf,doc,docx

# Payment Gateway (if needed)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# SMS Service (for notifications)
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+1234567890

# Analytics & Monitoring
GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X
SENTRY_DSN=https://your-sentry-dsn.ingest.sentry.io/

# Health Check
HEALTH_CHECK_ENDPOINT=/health
HEALTH_CHECK_DETAILED=/health/detailed

# Feature Flags
ENABLE_SWAGGER=true
ENABLE_MORGAN_LOGGING=true
ENABLE_REDIS_CACHE=false
ENABLE_EMAIL_VERIFICATION=true
ENABLE_TWO_FACTOR_AUTH=false
ENABLE_PUSH_NOTIFICATIONS=false

# Logging
LOG_LEVEL=debug
LOG_FILE=logs/app.log

# External APIs
GOOGLE_MAPS_API_KEY=your-google-maps-key
FIREBASE_SERVER_KEY=your-firebase-server-key